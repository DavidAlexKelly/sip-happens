{
  "expo": {
    "name": "Betterlo",
    "slug": "betterlo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0e0e11",
    "splash": {
      "backgroundColor": "#0e0e11",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.electricnocturne",
      "infoPlist": {
        "UIRequiresFullScreen": true,
        "NSCameraUsageDescription": "Used to set your player photo.",
        "NSPhotoLibraryUsageDescription": "Used to access photos for your player icon."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0e0e11"
      },
      "package": "com.yourname.electricnocturne",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Used to set your player photo.",
          "photosPermission": "Used to access photos for your player icon."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9c1b8c73-7891-4001-bb46-aa2fdccd67aa"
      }
    },
    "owner": "dkellyyyys-organization",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9c1b8c73-7891-4001-bb46-aa2fdccd67aa"
    }
  }
}
